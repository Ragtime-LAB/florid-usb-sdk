@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

list(APPEND CMAKE_MODULE_PATH "${CMAKE_CURRENT_LIST_DIR}/Modules")

include("${CMAKE_CURRENT_LIST_DIR}/Modules/FindTlExpected.cmake")
find_dependency(Liburing)

list(REMOVE_AT CMAKE_MODULE_PATH -1 -1)

if(NOT TARGET HySerial::HySerial)
  include("${CMAKE_CURRENT_LIST_DIR}/HySerialTargets.cmake")
endif()

check_required_components(HySerial)
